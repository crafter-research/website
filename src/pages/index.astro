---
import Layout from "../layouts/Layout.astro";

const projects = [
	{
		name: "Congreso Legible",
		description:
			"LLM-powered plain-language summaries of Peruvian congressional bills. Real-time status tracking, semantic search, and RSS alerts.",
		status: "Shaping",
		repo: "crafter-research/ley-clara",
	},
	{
		name: "Plata.pe",
		description:
			"Political finance transparency via Sankey diagrams. Structured extraction from ONPE/JNE data into queryable, open datasets.",
		status: "Shaping",
		repo: "crafter-research/plata-pe",
	},
	{
		name: "Capibarismo",
		description:
			"Gamified civic engagement platform for Peru's 2026 elections. Candidate comparison through an interactive voting game.",
		status: "Active",
		repo: "crafter-station/capibarismo",
	},
];
---

<Layout
	title="Crafter Research"
	description="A research lab where every paper has a working prototype."
>
	<main class="mx-auto max-w-2xl px-6 py-24">
		<header class="mb-20">
			<p
				class="text-(--color-muted) mb-4 font-mono text-sm tracking-widest uppercase"
			>
				crafter research
			</p>
			<h1 class="mb-6 text-4xl font-bold tracking-tight sm:text-5xl">
				Testing Hypotheses
			</h1>
			<p class="text-(--color-accent) text-lg leading-relaxed">
				A research lab where every paper has a working prototype. We build
				open-source civic technology for Peru — tools that make political
				behavior transparent, legislation legible, and public data queryable.
			</p>
		</header>

		<section class="mb-20">
			<h2
				class="text-(--color-muted) mb-8 font-mono text-xs tracking-widest uppercase"
			>
				Currently exploring
			</h2>
			<div class="space-y-6">
				{
					projects.map((project) => (
						<a
							href={`https://github.com/${project.repo}`}
							target="_blank"
							rel="noopener noreferrer"
							class="border-(--color-border) hover:border-(--color-muted) block rounded-lg border p-5 transition-colors"
						>
							<div class="mb-2 flex items-center gap-3">
								<h3 class="font-medium">{project.name}</h3>
								<span class="bg-(--color-surface) text-(--color-muted) rounded-full px-2 py-0.5 font-mono text-xs">
									{project.status}
								</span>
							</div>
							<p class="text-(--color-muted) text-sm leading-relaxed">
								{project.description}
							</p>
						</a>
					))
				}
			</div>
		</section>

		<section class="border-(--color-border) mb-20 border-t pt-10">
			<h2
				class="text-(--color-muted) mb-4 font-mono text-xs tracking-widest uppercase"
			>
				What's next
			</h2>
			<ul class="text-(--color-accent) space-y-2 text-sm">
				<li>Congresista Score — legislator profiles by output, not credentials</li>
				<li>Broad Listening AI — opinion clustering for public consultations</li>
				<li>AI Fact Checker — claim verification against structured civic data</li>
			</ul>
		</section>

		<footer
			class="border-(--color-border) text-(--color-muted) flex items-center justify-between border-t pt-8 text-sm"
		>
			<a
				href="https://crafterstation.com"
				target="_blank"
				rel="noopener noreferrer"
				class="hover:text-(--color-text) transition-colors"
			>
				Crafter Station
			</a>
			<div class="flex gap-4">
				<a
					href="https://github.com/crafter-research"
					target="_blank"
					rel="noopener noreferrer"
					class="hover:text-(--color-text) transition-colors"
				>
					GitHub
				</a>
				<a
					href="https://x.com/crafaboratorio"
					target="_blank"
					rel="noopener noreferrer"
					class="hover:text-(--color-text) transition-colors"
				>
					X
				</a>
			</div>
		</footer>
	</main>
</Layout>
